# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit real keys.

# Free tier — Google Gemini via AI Studio (default)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Pro tier — Anthropic Claude (optional, for higher-quality runs)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model tier: "free" (Gemini 2.5 Flash) or "pro" (Claude Sonnet 4.6)
# Default: "free"
MODEL_TIER=free
